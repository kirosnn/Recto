{
  "productName": "Recto Dev",
  "identifier": "com.recto.dev.recto",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --port 5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
